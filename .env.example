# Application and primary database classification. APP_ENV and
# DATABASE_ENVIRONMENT must match exactly.
APP_ENV="development"
DATABASE_ENVIRONMENT="development"
# Manual Lead Creation is fail-closed in every environment. Set the exact value
# "true" only for an explicitly approved environment. Production and Preview
# require Project Shield and company/privacy-owner approval before enablement.
MANUAL_LEAD_CREATION_ENABLED="false"
DATABASE_URL="postgres://USER:PASSWORD@DEVELOPMENT_HOST:5432/seai_solar_grants?sslmode=require"
DATABASE_BRANCH_ID="development-branch-id"
# Run `pnpm db:fingerprint` after setting the URL and branch ID, then copy only
# the resulting fingerprint value here. The Production fingerprint is the
# positive marker for the one approved Production database and is required in
# every environment.
DATABASE_FINGERPRINT="db_replace_with_development_fingerprint"
PRODUCTION_DATABASE_FINGERPRINT="db_replace_with_production_fingerprint"
# Required by the integration runner to prove its target is not a persistent
# Preview or Development database.
PREVIEW_DATABASE_FINGERPRINT="db_replace_with_preview_fingerprint"
DEVELOPMENT_DATABASE_FINGERPRINT="db_replace_with_development_fingerprint"

# Disposable PostgreSQL integration database. Never reuse DATABASE_URL.
TEST_DATABASE_ENVIRONMENT="test"
TEST_DATABASE_URL="postgres://USER:PASSWORD@TEST_HOST:5432/seai_solar_grants_test?sslmode=require"
TEST_DATABASE_BRANCH_ID="disposable-test-branch-id"
TEST_DATABASE_FINGERPRINT="db_replace_with_test_fingerprint"

OPENAI_API_KEY=""
APP_URL="http://localhost:3000"
DEFAULT_INSTALLER_ID="demo-installer"
DEFAULT_INSTALLER_NAME="Demo Solar"
DEFAULT_INSTALLER_SEAI_ID="SEAI-12345"
DEFAULT_INSTALLER_WEBSITE_DOMAIN="demo-solar.ie"
DEFAULT_INSTALLER_COUNTY="Dublin"

# Required at runtime. Generate a high-entropy value of at least 32 characters.
AUTH_SESSION_PEPPER=""

# Required only while running `pnpm pilot:provision`.
PILOT_ORGANISATION_NAME=""
PILOT_ORGANISATION_SLUG=""
PILOT_OWNER_NAME=""
PILOT_OWNER_EMAIL=""
PILOT_OWNER_PASSWORD=""
PILOT_INSTALLER_SEAI_COMPANY_ID=""
PILOT_INSTALLER_WEBSITE_DOMAIN=""
PILOT_INSTALLER_COUNTY=""
# Production provisioning additionally requires both values below.
ACKNOWLEDGE_PRODUCTION_PROVISIONING=""
PRODUCTION_PROVISION_CHANGE_ID=""

EMAIL_USER=""
EMAIL_PASS=""

TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_PHONE_NUMBER=""
INSTALLER_PHONE_NUMBER=""
