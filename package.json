{
  "name": "seai-solar-grant-assistant",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.11.0",
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "postinstall": "prisma generate",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "node scripts/run-unit-tests.mjs",
    "test:integration:postgres": "node --import tsx scripts/run-postgres-integration-tests.ts",
    "prisma:generate": "prisma generate",
    "db:fingerprint": "node --import tsx scripts/run-database-command.ts fingerprint",
    "db:status": "node --import tsx scripts/run-database-command.ts status",
    "db:migrate:development": "node --import tsx scripts/run-database-command.ts migrate-development",
    "db:migrate:preview": "node --import tsx scripts/run-database-command.ts migrate-preview",
    "db:migrate:test": "node --import tsx scripts/run-database-command.ts migrate-test",
    "db:migrate:production": "node --import tsx scripts/run-database-command.ts migrate-production",
    "db:reset": "node --import tsx scripts/run-database-command.ts reset",
    "db:seed:development": "node --import tsx scripts/run-database-command.ts seed-development",
    "db:seed:test": "node --import tsx scripts/run-database-command.ts seed-test",
    "pilot:provision": "node --import tsx scripts/provision-pilot-user.ts",
    "tenant:provision": "node --import tsx scripts/tenant-provision.ts"
  },
  "dependencies": {
    "@node-rs/argon2": "^2.0.2",
    "@prisma/client": "^5.22.0",
    "next": "^15.0.0",
    "nodemailer": "^6.10.1",
    "openai": "^4.71.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "twilio": "^6.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@types/node": "^22.9.0",
    "@types/nodemailer": "^6.4.17",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "eslint": "^9.39.4",
    "eslint-config-next": "^15.5.15",
    "prisma": "^5.22.0",
    "tsx": "^4.19.1",
    "typescript": "^5.6.3"
  }
}
