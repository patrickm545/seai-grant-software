generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum LeadStatus {
  NEW
  NEEDS_REVIEW
  READY_TO_APPLY
  HOMEOWNER_REVIEW_PENDING
  SUBMITTED
  INSTALLATION_PENDING
  PAYMENT_DOCS_PENDING
  COMPLETED
}

enum LeadPipelineStage {
  NEW_LEAD
  CONTACTED
  QUALIFIED
  SURVEY_BOOKED
  SURVEY_COMPLETED
  QUOTE_SENT
  WON
  LOST
}

enum LeadScore {
  HOT
  WARM
  COLD
}

enum LeadActivityType {
  LEAD_CREATED
  STAGE_CHANGED
  SCORE_UPDATED
  NOTE_ADDED
  EMAIL_SENT
  SMS_SENT
  DOCUMENT_UPLOADED
  DOCUMENT_APPROVED
  DOCUMENT_REJECTED
  DOCUMENT_NEEDS_REPLACEMENT
  PORTAL_TOKEN_CREATED
  PORTAL_TOKEN_REGENERATED
  PORTAL_ACCESSED
  PROPOSAL_VIEWED
  QUOTE_SENT
  FOLLOW_UP_SET
  SYSTEM_EVENT
}

enum LeadDocumentType {
  ELECTRICITY_BILL
  BER_CERTIFICATE
  PROPERTY_PHOTO
  ADDRESS_CONFIRMATION
  SIGNED_CONTRACT
  OTHER
}

enum LeadDocumentStatus {
  UPLOADED
  APPROVED
  REJECTED
  NEEDS_REPLACEMENT
}

enum DwellingType {
  DETACHED
  SEMI_DETACHED
  TERRACED
  MID_TERRACE
  END_TERRACE
  APARTMENT
  BUNGALOW
  OTHER
}

enum OrganisationType {
  CLADA_INTERNAL
  INSTALLER
}

enum OrganisationStatus {
  ACTIVE
  INACTIVE
}

enum UserStatus {
  ACTIVE
  INACTIVE
}

enum OrganisationMembershipStatus {
  ACTIVE
  INACTIVE
}

model Organisation {
  id          String                     @id @default(cuid())
  name        String
  type        OrganisationType
  status      OrganisationStatus         @default(ACTIVE)
  createdAt   DateTime                   @default(now())
  updatedAt   DateTime                   @updatedAt
  installers  Installer[]
  leads       Lead[]
  memberships OrganisationMembership[]

  @@index([type, status])
}

model User {
  id          String                     @id @default(cuid())
  email       String                     @unique
  displayName String
  status      UserStatus                 @default(ACTIVE)
  createdAt   DateTime                   @default(now())
  updatedAt   DateTime                   @updatedAt
  memberships OrganisationMembership[]

  @@index([status])
}

model OrganisationMembership {
  id             String                       @id @default(cuid())
  organisationId String
  userId         String
  organisation   Organisation                 @relation(fields: [organisationId], references: [id], onDelete: Cascade)
  user           User                         @relation(fields: [userId], references: [id], onDelete: Cascade)
  status         OrganisationMembershipStatus @default(ACTIVE)
  isOwner        Boolean                      @default(false)
  createdAt      DateTime                     @default(now())
  updatedAt      DateTime                     @updatedAt

  @@unique([organisationId, userId])
  @@index([userId, status])
  @@index([organisationId, status])
}

model Installer {
  id             String                  @id @default(cuid())
  organisationId String
  organisation   Organisation            @relation(fields: [organisationId], references: [id])
  name           String
  seaiCompanyId  String
  websiteDomain  String?
  county         String?
  createdAt      DateTime                @default(now())
  updatedAt      DateTime                @updatedAt
  leads          Lead[]
  quotePricing   InstallerQuotePricing?

  @@index([organisationId])
}

model Lead {
  id                    String        @id @default(cuid())
  organisationId        String
  organisation          Organisation  @relation(fields: [organisationId], references: [id])
  installerId           String
  installer             Installer     @relation(fields: [installerId], references: [id])
  fullName              String
  email                 String
  phone                 String?
  addressLine1          String
  addressLine2          String?
  county                String
  eircode               String?
  propertyOwner         Boolean
  privateLandlord       Boolean       @default(false)
  dwellingType          DwellingType
  yearBuilt             Int
  yearOccupied          Int?
  mprn                  String
  worksStarted          Boolean
  priorSolarGrantAtMprn Boolean       @default(false)
  consentToProcess      Boolean
  consentToGrantAssist  Boolean
  consentToContact      Boolean       @default(false)
  notes                 String?
  internalNotes         String?
  followUpDate          DateTime?
  assignedAdmin         String?
  assignedInstaller     String?
  currentCrmProcess     String?
  installerSize         String?
  objections            String?
  painPoints            String?
  likelihoodToBuy       String?
  leadSource            String?
  portalToken           String?       @unique
  portalTokenCreatedAt  DateTime?
  portalLastAccessedAt  DateTime?
  pipelineStage         LeadPipelineStage @default(NEW_LEAD)
  leadScore             LeadScore         @default(WARM)
  lastContactedAt       DateTime?
  nextFollowUpAt        DateTime?
  scoreUpdatedAt        DateTime?
  researchCallCompleted Boolean       @default(false)
  salesCallRequired     Boolean       @default(false)
  status                LeadStatus    @default(NEW)
  aiSummary             String?
  likelyEligible        Boolean?
  eligibilityConfidence Float?
  risksJson             Json?
  missingItemsJson      Json?
  structuredExportJson  Json?
  generatedQuoteJson    Json?
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt
  documents             LeadDocument[]
  activities            LeadActivity[]

  @@index([organisationId, createdAt])
  @@index([organisationId, installerId])
}

model InstallerQuotePricing {
  id                    String    @id @default(cuid())
  installerId           String    @unique
  installer             Installer @relation(fields: [installerId], references: [id], onDelete: Cascade)
  panelUnitCost         Float     @default(320)
  panelKwCost           Float     @default(0)
  batteryUnitCost       Float     @default(3500)
  batteryKwhCost        Float     @default(0)
  inverterCost          Float     @default(1200)
  mountingCost          Float     @default(850)
  wiringCost            Float     @default(450)
  safetyEquipmentCost   Float     @default(350)
  baseLabourCost        Float     @default(1200)
  labourPerPanel        Float     @default(65)
  labourPerKw           Float     @default(0)
  electricalWorkCost    Float     @default(650)
  surveyAdminCost       Float     @default(250)
  miscellaneousCost     Float     @default(300)
  optionalExtrasCost    Float     @default(0)
  markupPercentage      Float     @default(12)
  vatPercentage         Float     @default(13.5)
  discountPercentage    Float     @default(0)
  discountFixedAmount   Float     @default(0)
  minimumQuotePrice     Float     @default(0)
  travelCost            Float     @default(0)
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([installerId])
}

model LeadDocument {
  id               String             @id @default(cuid())
  leadId           String
  lead             Lead               @relation(fields: [leadId], references: [id], onDelete: Cascade)
  type             LeadDocumentType   @default(OTHER)
  fileName         String
  originalFilename String?
  mimeType         String
  sizeBytes        Int?
  storagePath      String?
  storageUrl       String?
  contentBytes     Bytes?
  uploadedBy       String?
  uploadedByRole   String?
  status           LeadDocumentStatus @default(UPLOADED)
  extractedText    String?
  aiFieldsJson     Json?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  @@index([leadId, type])
  @@index([status])
  @@index([createdAt])
}

model LeadActivity {
  id            String           @id @default(cuid())
  leadId        String
  lead          Lead             @relation(fields: [leadId], references: [id], onDelete: Cascade)
  type          LeadActivityType
  title         String
  description   String?
  metadata      Json?
  createdAt     DateTime         @default(now())
  createdBy     String?
  createdByRole String?

  @@index([leadId, createdAt])
  @@index([type])
  @@index([createdAt])
}

model AuditLog {
  id           String   @id @default(cuid())
  leadId       String?
  action       String
  actor        String
  createdAt    DateTime @default(now())
  metadataJson Json?

  @@index([leadId])
  @@index([createdAt])
}
