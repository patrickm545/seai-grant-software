generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum LeadStatus {
  NEW
  NEEDS_REVIEW
  READY_TO_APPLY
  HOMEOWNER_REVIEW_PENDING
  SUBMITTED
  INSTALLATION_PENDING
  PAYMENT_DOCS_PENDING
  COMPLETED
}

enum LeadPipelineStage {
  NEW_LEAD
  CONTACTED
  QUALIFIED
  SURVEY_BOOKED
  SURVEY_COMPLETED
  QUOTE_SENT
  WON
  LOST
}

enum LeadScore {
  HOT
  WARM
  COLD
}

enum LeadActivityType {
  LEAD_CREATED
  STAGE_CHANGED
  SCORE_UPDATED
  NOTE_ADDED
  EMAIL_SENT
  SMS_SENT
  DOCUMENT_UPLOADED
  DOCUMENT_APPROVED
  DOCUMENT_REJECTED
  DOCUMENT_NEEDS_REPLACEMENT
  PORTAL_TOKEN_CREATED
  PORTAL_TOKEN_REGENERATED
  PORTAL_ACCESSED
  PROPOSAL_VIEWED
  QUOTE_SENT
  FOLLOW_UP_SET
  SYSTEM_EVENT
}

enum LeadDocumentType {
  ELECTRICITY_BILL
  BER_CERTIFICATE
  PROPERTY_PHOTO
  ADDRESS_CONFIRMATION
  SIGNED_CONTRACT
  OTHER
}

enum LeadDocumentStatus {
  UPLOADED
  APPROVED
  REJECTED
  NEEDS_REPLACEMENT
}

enum DwellingType {
  DETACHED
  SEMI_DETACHED
  TERRACED
  MID_TERRACE
  END_TERRACE
  APARTMENT
  BUNGALOW
  OTHER
}

enum OrganisationType {
  CLADA_INTERNAL
  INSTALLER
}

enum OrganisationStatus {
  PROVISIONING
  ACTIVE
  INACTIVE
  ARCHIVED
}

enum UserStatus {
  INVITED
  ACTIVE
  INACTIVE
}

enum AuthSessionType {
  NORMAL
  RESTRICTED_FIRST_LOGIN
}

enum ProvisioningOperationStatus {
  PENDING
  VALIDATING
  READY
  COMPLETED
  FAILED
  CANCELLED
}

enum ProvisioningOperationType {
  PROVISIONING
  RECOVERY_CREDENTIAL_REISSUE
  RECOVERY_SUSPEND_USER
  RECOVERY_SUSPEND_ORGANISATION
  RECOVERY_REACTIVATE_USER
  RECOVERY_REACTIVATE_ORGANISATION
}

enum OrganisationMembershipStatus {
  ACTIVE
  INACTIVE
}

enum PlatformRole {
  ORGANISATION_OWNER
  ORGANISATION_ADMIN
  ORGANISATION_MEMBER
  CLADA_INTERNAL_ADMIN
  CLADA_INTERNAL_SUPPORT
  SERVICE_ACTOR
  SYSTEM_ACTOR
}

enum AuditActorType {
  HUMAN_USER
  SYSTEM
  SERVICE
  PUBLIC_TOKEN
}

enum AuditOutcome {
  SUCCEEDED
  DENIED
  FAILED
}

model Organisation {
  id                     String                   @id @default(cuid())
  name                   String
  slug                   String                   @unique
  type                   OrganisationType
  status                 OrganisationStatus       @default(ACTIVE)
  verified               Boolean                  @default(false)
  createdAt              DateTime                 @default(now())
  updatedAt              DateTime                 @updatedAt
  installers             Installer[]
  leads                  Lead[]
  memberships            OrganisationMembership[]
  provisioningOperations ProvisioningOperation[]
  workflowInstances      WorkflowInstance[]
  workflowHistories      WorkflowHistory[]

  @@index([type, status])
}

model User {
  id                             String                   @id @default(cuid())
  email                          String                   @unique
  displayName                    String
  passwordHash                   String?
  status                         UserStatus               @default(ACTIVE)
  mustChangePassword             Boolean                  @default(false)
  temporaryCredentialExpiresAt   DateTime?
  lastLoginAt                    DateTime?
  createdAt                      DateTime                 @default(now())
  updatedAt                      DateTime                 @updatedAt
  memberships                    OrganisationMembership[]
  sessions                       AuthSession[]
  approvedProvisioningOperations ProvisioningOperation[]  @relation("ProvisioningApprovedBy")

  @@index([status])
}

model OrganisationMembership {
  id             String                       @id @default(cuid())
  organisationId String
  userId         String
  organisation   Organisation                 @relation(fields: [organisationId], references: [id], onDelete: Cascade)
  user           User                         @relation(fields: [userId], references: [id], onDelete: Cascade)
  status         OrganisationMembershipStatus @default(ACTIVE)
  isOwner        Boolean                      @default(false)
  role           PlatformRole                 @default(ORGANISATION_MEMBER)
  createdAt      DateTime                     @default(now())
  updatedAt      DateTime                     @updatedAt

  @@unique([organisationId, userId])
  @@unique([userId])
  @@index([userId, status])
  @@index([organisationId, status])
  @@index([role])
}

model AuthSession {
  id          String          @id @default(cuid())
  userId      String
  tokenHash   String          @unique
  sessionType AuthSessionType
  expiresAt   DateTime
  createdAt   DateTime        @default(now())
  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
  @@index([userId, sessionType, expiresAt])
  @@index([expiresAt])
}

model Installer {
  id             String                 @id @default(cuid())
  organisationId String
  organisation   Organisation           @relation(fields: [organisationId], references: [id])
  name           String
  slug           String                 @unique
  seaiCompanyId  String
  websiteDomain  String?
  county         String?
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt
  leads          Lead[]
  quotePricing   InstallerQuotePricing?

  @@unique([id, organisationId])
  @@index([organisationId])
}

model ProvisioningOperation {
  id             String                      @id @default(cuid())
  idempotencyKey String                      @unique
  inputHash      String
  operationType  ProvisioningOperationType   @default(PROVISIONING)
  status         ProvisioningOperationStatus @default(PENDING)
  organisationId String?
  organisation   Organisation?               @relation(fields: [organisationId], references: [id], onDelete: SetNull)
  approvedBy     String?
  approver       User?                       @relation("ProvisioningApprovedBy", fields: [approvedBy], references: [id], onDelete: Restrict)
  approvedAt     DateTime?
  completedAt    DateTime?
  createdAt      DateTime                    @default(now())
  updatedAt      DateTime                    @updatedAt
  auditLogs      AuditLog[]

  @@index([status, createdAt])
  @@index([organisationId])
  @@index([approvedBy])
}

model Lead {
  id                    String            @id @default(cuid())
  organisationId        String
  organisation          Organisation      @relation(fields: [organisationId], references: [id])
  installerId           String
  installer             Installer         @relation(fields: [installerId, organisationId], references: [id, organisationId])
  fullName              String
  email                 String
  phone                 String?
  addressLine1          String
  addressLine2          String?
  county                String
  eircode               String?
  propertyOwner         Boolean
  privateLandlord       Boolean           @default(false)
  dwellingType          DwellingType
  yearBuilt             Int
  yearOccupied          Int?
  mprn                  String
  worksStarted          Boolean
  priorSolarGrantAtMprn Boolean           @default(false)
  consentToProcess      Boolean
  consentToGrantAssist  Boolean
  consentToContact      Boolean           @default(false)
  notes                 String?
  internalNotes         String?
  followUpDate          DateTime?
  assignedAdmin         String?
  assignedInstaller     String?
  currentCrmProcess     String?
  installerSize         String?
  objections            String?
  painPoints            String?
  likelihoodToBuy       String?
  leadSource            String?
  portalToken           String?           @unique
  portalTokenCreatedAt  DateTime?
  portalLastAccessedAt  DateTime?
  pipelineStage         LeadPipelineStage @default(NEW_LEAD)
  leadScore             LeadScore         @default(WARM)
  lastContactedAt       DateTime?
  nextFollowUpAt        DateTime?
  scoreUpdatedAt        DateTime?
  researchCallCompleted Boolean           @default(false)
  salesCallRequired     Boolean           @default(false)
  status                LeadStatus        @default(NEW)
  aiSummary             String?
  likelyEligible        Boolean?
  eligibilityConfidence Float?
  risksJson             Json?
  missingItemsJson      Json?
  structuredExportJson  Json?
  generatedQuoteJson    Json?
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt
  documents             LeadDocument[]
  activities            LeadActivity[]

  @@index([organisationId, createdAt])
  @@index([organisationId, installerId])
}

model InstallerQuotePricing {
  id                  String    @id @default(cuid())
  installerId         String    @unique
  installer           Installer @relation(fields: [installerId], references: [id], onDelete: Cascade)
  panelUnitCost       Float     @default(320)
  panelKwCost         Float     @default(0)
  batteryUnitCost     Float     @default(3500)
  batteryKwhCost      Float     @default(0)
  inverterCost        Float     @default(1200)
  mountingCost        Float     @default(850)
  wiringCost          Float     @default(450)
  safetyEquipmentCost Float     @default(350)
  baseLabourCost      Float     @default(1200)
  labourPerPanel      Float     @default(65)
  labourPerKw         Float     @default(0)
  electricalWorkCost  Float     @default(650)
  surveyAdminCost     Float     @default(250)
  miscellaneousCost   Float     @default(300)
  optionalExtrasCost  Float     @default(0)
  markupPercentage    Float     @default(12)
  vatPercentage       Float     @default(13.5)
  discountPercentage  Float     @default(0)
  discountFixedAmount Float     @default(0)
  minimumQuotePrice   Float     @default(0)
  travelCost          Float     @default(0)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@index([installerId])
}

model LeadDocument {
  id               String             @id @default(cuid())
  leadId           String
  lead             Lead               @relation(fields: [leadId], references: [id], onDelete: Cascade)
  type             LeadDocumentType   @default(OTHER)
  fileName         String
  originalFilename String?
  mimeType         String
  sizeBytes        Int?
  storagePath      String?
  storageUrl       String?
  contentBytes     Bytes?
  uploadedBy       String?
  uploadedByRole   String?
  status           LeadDocumentStatus @default(UPLOADED)
  extractedText    String?
  aiFieldsJson     Json?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  @@index([leadId, type])
  @@index([status])
  @@index([createdAt])
}

model LeadActivity {
  id                  String           @id @default(cuid())
  leadId              String
  lead                Lead             @relation(fields: [leadId], references: [id], onDelete: Cascade)
  type                LeadActivityType
  title               String
  description         String?
  metadata            Json?
  createdAt           DateTime         @default(now())
  createdBy           String?
  createdByRole       String?
  actorType           AuditActorType?
  actorUserId         String?
  actorMembershipId   String?
  actorOrganisationId String?

  @@index([leadId, createdAt])
  @@index([type])
  @@index([createdAt])
  @@index([actorOrganisationId, createdAt])
  @@index([actorUserId])
}

model AuditLog {
  id                      String                 @id @default(cuid())
  leadId                  String?
  organisationId          String?
  action                  String
  actor                   String
  actorType               AuditActorType?
  userId                  String?
  membershipId            String?
  resourceType            String?
  resourceId              String?
  source                  String?
  outcome                 AuditOutcome           @default(SUCCEEDED)
  createdAt               DateTime               @default(now())
  metadataJson            Json?
  provisioningOperationId String?
  provisioningOperation   ProvisioningOperation? @relation(fields: [provisioningOperationId], references: [id], onDelete: SetNull)
  workflowHistories       WorkflowHistory[]

  @@index([leadId])
  @@index([organisationId, createdAt])
  @@index([actorType])
  @@index([userId])
  @@index([membershipId])
  @@index([resourceType, resourceId])
  @@index([outcome])
  @@index([createdAt])
  @@index([provisioningOperationId, createdAt])
}

model WorkflowDefinition {
  id          String               @id @default(cuid())
  key         String
  name        String
  description String?
  version     Int                  @default(1)
  isActive    Boolean              @default(true)
  metadata    Json?
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
  stages      WorkflowStage[]
  transitions WorkflowTransition[]
  instances   WorkflowInstance[]
  histories   WorkflowHistory[]

  @@unique([key, version])
  @@index([key, isActive])
}

model WorkflowStage {
  id                   String               @id @default(cuid())
  workflowDefinitionId String
  workflowDefinition   WorkflowDefinition   @relation(fields: [workflowDefinitionId], references: [id], onDelete: Cascade)
  key                  String
  label                String
  position             Int
  isInitial            Boolean              @default(false)
  isTerminal           Boolean              @default(false)
  metadata             Json?
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt
  outgoingTransitions  WorkflowTransition[] @relation("WorkflowTransitionFromStage")
  incomingTransitions  WorkflowTransition[] @relation("WorkflowTransitionToStage")
  currentInstances     WorkflowInstance[]
  previousHistories    WorkflowHistory[]    @relation("WorkflowHistoryPreviousStage")
  nextHistories        WorkflowHistory[]    @relation("WorkflowHistoryNextStage")

  @@unique([workflowDefinitionId, key])
  @@unique([workflowDefinitionId, position])
  @@unique([id, workflowDefinitionId])
  @@index([workflowDefinitionId, isInitial])
  @@index([workflowDefinitionId, isTerminal])
}

model WorkflowTransition {
  id                   String             @id @default(cuid())
  workflowDefinitionId String
  workflowDefinition   WorkflowDefinition @relation(fields: [workflowDefinitionId], references: [id], onDelete: Cascade)
  fromStageId          String
  fromStage            WorkflowStage      @relation("WorkflowTransitionFromStage", fields: [fromStageId, workflowDefinitionId], references: [id, workflowDefinitionId], onDelete: Restrict)
  toStageId            String
  toStage              WorkflowStage      @relation("WorkflowTransitionToStage", fields: [toStageId, workflowDefinitionId], references: [id, workflowDefinitionId], onDelete: Restrict)
  key                  String?
  label                String?
  requiredPermission   String?
  isActive             Boolean            @default(true)
  metadata             Json?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  histories            WorkflowHistory[]

  @@unique([workflowDefinitionId, fromStageId, toStageId])
  @@unique([id, workflowDefinitionId])
  @@index([workflowDefinitionId, isActive])
  @@index([fromStageId])
  @@index([toStageId])
}

model WorkflowInstance {
  id                   String             @id @default(cuid())
  workflowDefinitionId String
  workflowDefinition   WorkflowDefinition @relation(fields: [workflowDefinitionId], references: [id], onDelete: Restrict)
  currentStageId       String
  currentStage         WorkflowStage      @relation(fields: [currentStageId, workflowDefinitionId], references: [id, workflowDefinitionId], onDelete: Restrict)
  organisationId       String
  organisation         Organisation       @relation(fields: [organisationId], references: [id], onDelete: Restrict)
  resourceType         String
  resourceId           String
  startedAt            DateTime           @default(now())
  completedAt          DateTime?
  metadata             Json?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  histories            WorkflowHistory[]

  @@unique([workflowDefinitionId, resourceType, resourceId])
  @@unique([id, workflowDefinitionId, organisationId])
  @@index([organisationId, currentStageId])
  @@index([resourceType, resourceId])
  @@index([workflowDefinitionId, currentStageId])
}

model WorkflowHistory {
  id                   String              @id @default(cuid())
  workflowInstanceId   String
  workflowInstance     WorkflowInstance    @relation(fields: [workflowInstanceId, workflowDefinitionId, organisationId], references: [id, workflowDefinitionId, organisationId], onDelete: Cascade)
  workflowDefinitionId String
  workflowDefinition   WorkflowDefinition  @relation(fields: [workflowDefinitionId], references: [id], onDelete: Restrict)
  transitionId         String?
  transition           WorkflowTransition? @relation(fields: [transitionId, workflowDefinitionId], references: [id, workflowDefinitionId], onDelete: Restrict)
  previousStageId      String?
  previousStage        WorkflowStage?      @relation("WorkflowHistoryPreviousStage", fields: [previousStageId, workflowDefinitionId], references: [id, workflowDefinitionId], onDelete: Restrict)
  nextStageId          String?
  nextStage            WorkflowStage?      @relation("WorkflowHistoryNextStage", fields: [nextStageId, workflowDefinitionId], references: [id, workflowDefinitionId], onDelete: Restrict)
  previousStageKey     String
  nextStageKey         String
  organisationId       String
  organisation         Organisation        @relation(fields: [organisationId], references: [id], onDelete: Restrict)
  actorType            AuditActorType?
  actorUserId          String?
  actorMembershipId    String?
  actorOrganisationId  String?
  outcome              AuditOutcome        @default(SUCCEEDED)
  metadata             Json?
  auditLogId           String?             @unique
  auditLog             AuditLog?           @relation(fields: [auditLogId], references: [id], onDelete: SetNull)
  createdAt            DateTime            @default(now())

  @@index([workflowInstanceId, createdAt])
  @@index([workflowDefinitionId, createdAt])
  @@index([organisationId, createdAt])
  @@index([outcome])
  @@index([actorUserId])
  @@index([actorMembershipId])
  @@index([transitionId])
}
